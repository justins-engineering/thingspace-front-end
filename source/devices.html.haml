---
title: Devices
---

%main.grow.grid.grid-cols-12.grid-rows-12{'x-data': 'deviceTable'}
  .row-span-1.col-start-2.col-span-10.self-end
    .flex.flex-row.mb-2
      %h1.text-white.text-lg.font-semibold.mr-2 Devices
      %button{
          '@click': 'newTable = await getTable()',
          class: ['hover:text-teal-500', 'rounded-sm', 'dark:hover:bg-white/12.5',
                  'p-2', 'text-sm', 'leading-none', 'text-white', 'no-underline',
                  'hover:bg-gray-950/7.5', 'sm:mt-0']
        }
        %i.fa-solid.fa-rotate-right

  .row-span-10.col-start-2.col-span-10
    %table.table-auto.w-full.bg-white.dark:bg-slate-800.text-sm.border.border-slate-400.dark:border-slate-500
      %thead.font-semibold.text-slate-900.dark:text-slate-200.bg-slate-50.dark:bg-slate-700
        %tr.divide-x.divide-slate-300.dark:divide-slate-600.border-b.border-slate-300.dark:border-slate-600
          %th.p-1 Location
          %th.p-1 Device identifier
          %th.p-1 ICCID
          %th.p-1 MSISDN
          %th.p-1 Connection
          %th.p-1 Last connection date
          %th.p-1 Data usage
      %tbody.text-slate-500.dark:text-slate-400.divide-y.divide-slate-300.dark:divide-slate-700{
        'x-html': "newTable ? newTable : $el.innerHTML"
      }
        = partial :device_table
